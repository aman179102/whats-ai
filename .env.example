APP_NAME="WhatsAI"
APP_ENV=development
APP_DEBUG=true

# Database (SQLite - file path)
DB_PATH=storage/database.sqlite

# WhatsApp Provider: meta | twilio | webscraper
WHATSAPP_PROVIDER=meta

# Meta Cloud API
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_API_VERSION=v21.0

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Web Scraper (UNOFFICIAL - Use at your own risk)
WEB_SCRAPER_SESSION_PATH=
WEB_SCRAPER_API_URL=
WEB_SCRAPER_API_KEY=

# AI Provider: openrouter | groq | gemini | custom
AI_PROVIDER=openrouter
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_SYSTEM_PROMPT="You are a helpful WhatsApp assistant. Keep replies concise."

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Custom OpenAI-compatible API
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# Scheduler
SCHEDULER_CHECK_INTERVAL=1
